10:["$","div",null,{"className":"space-y-4 mb-12","children":[["$","div","How often should commercial VCT floors be stripped and waxed?",{"className":"p-5 rounded-lg","style":{"background":"oklch(0.10 0 0)","border":"1px solid oklch(0.22 0.01 252 / 0.45)"},"children":[["$","p",null,{"className":"text-sm font-600 mb-2","style":{"color":"oklch(0.88 0 0)","fontFamily":"var(--font-heading)"},"children":"How often should commercial VCT floors be stripped and waxed?"}],["$","p",null,{"className":"text-sm leading-[1.7]","style":{"color":"oklch(0.58 0 0)","fontFamily":"var(--font-body)"},"children":"For typical commercial traffic, a full strip and wax cycle once or twice per year is standard, supplemented by monthly or quarterly buffing to maintain sheen between cycles. High-traffic corridors may require more frequent buffing."}]]}],["$","div","Can you work overnight to avoid disrupting business hours?",{"className":"p-5 rounded-lg","style":{"background":"oklch(0.10 0 0)","border":"1px solid oklch(0.22 0.01 252 / 0.45)"},"children":[["$","p",null,{"className":"text-sm font-600 mb-2","style":{"color":"oklch(0.88 0 0)","fontFamily":"var(--font-heading)"},"children":"Can you work overnight to avoid disrupting business hours?"}],["$","p",null,{"className":"text-sm leading-[1.7]","style":{"color":"oklch(0.58 0 0)","fontFamily":"var(--font-body)"},"children":"Yes — floor care projects typically require areas to be cleared and dry before foot traffic resumes. Overnight or weekend scheduling is standard for floor care work."}]]}],["$","div","Do you carry your own floor care equipment?",{"className":"p-5 rounded-lg","style":{"background":"oklch(0.10 0 0)","border":"1px solid oklch(0.22 0.01 252 / 0.45)"},"children":[["$","p",null,{"className":"text-sm font-600 mb-2","style":{"color":"oklch(0.88 0 0)","fontFamily":"var(--font-heading)"},"children":"Do you carry your own floor care equipment?"}],["$","p",null,{"className":"text-sm leading-[1.7]","style":{"color":"oklch(0.58 0 0)","fontFamily":"var(--font-body)"},"children":"Yes — our floor care team brings commercial-grade equipment including auto-scrubbers, high-speed burnishers, wet vacs, and appropriate chemical systems. No facility-supplied equipment is needed."}]]}]]}]
